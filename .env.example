# API Base URL
# The URL for the backend API (e.g., http://localhost:8080/api)
NEXT_PUBLIC_BASE_API_URL=http://localhost:8080/

# Marketing site URL
# Public URL of the landing page used for links that open outside the app
NEXT_PUBLIC_SITE_URL=https://www.scooli.app

# Clerk Authentication
# Sign up at https://clerk.com/ to get these keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Vercel Automation
# Used for Vercel Preview Deployment protection/automation
VERCEL_AUTOMATION_BYPASS_SECRET=

# PostHog (enable only in production)
NEXT_PUBLIC_POSTHOG_ENABLED=false
POSTHOG_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROXY_PATH=/_ph
